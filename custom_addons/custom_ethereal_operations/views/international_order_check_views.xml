<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_ethereal_international_order_check_tree" model="ir.ui.view">
        <field name="name">ethereal.international.order.check.tree</field>
        <field name="model">ethereal.international.order.check</field>
        <field name="arch" type="xml">
            <tree string="Control de pedidos internacionales">
                <field name="name"/>
                <field name="sale_order_id"/>
                <field name="partner_id"/>
                <field name="destination_country_id"/>
                <field name="check_date"/>
                <field name="check_type"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <record id="view_ethereal_international_order_check_form" model="ir.ui.view">
        <field name="name">ethereal.international.order.check.form</field>
        <field name="model">ethereal.international.order.check</field>
        <field name="arch" type="xml">
            <form string="Control de pedido internacional">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="sale_order_id"/>
                            <field name="partner_id"/>
                            <field name="destination_country_id"/>
                        </group>
                        <group>
                            <field name="check_date"/>
                            <field name="check_type"/>
                            <field name="state"/>
                        </group>
                    </group>
                    <group>
                        <field name="notes"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_ethereal_international_order_check" model="ir.actions.act_window">
        <field name="name">Control de pedidos internacionales</field>
        <field name="res_model">ethereal.international.order.check</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>